<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ZTProxy"
        android:textSize="24sp"
        android:textStyle="bold"
        android:layout_marginBottom="24dp" />

    <!-- Service Status Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SOCKS Proxy Status"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_marginBottom="16dp"
        android:padding="12dp"
        android:background="@drawable/box_background"
        android:gravity="center_vertical">

        <View
            android:id="@+id/statusIndicator"
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:background="@drawable/status_circle"
            android:layout_marginEnd="12dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/statusText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Status: Starting..."
                android:textSize="14sp" />

            <TextView
                android:id="@+id/proxyPortText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Port: 1080"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:alpha="0.7" />

            <TextView
                android:id="@+id/addressText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Address: 127.0.0.1"
                android:textSize="12sp"
                android:layout_marginTop="4dp"
                android:alpha="0.7" />
        </LinearLayout>

        <Button
            android:id="@+id/toggleButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stop"
            android:textSize="12sp"
            android:paddingHorizontal="12dp"
            android:paddingVertical="8dp" />
    </LinearLayout>

    <!-- ZeroTier Section -->
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="ZeroTier Network"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp"
        android:layout_marginTop="16dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginBottom="16dp"
        android:padding="12dp"
        android:background="@drawable/box_background">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Network ID (ZeroTier):"
            android:textSize="12sp"
            android:alpha="0.7"
            android:layout_marginBottom="4dp" />

        <EditText
            android:id="@+id/networkIdInput"
            android:layout_width="match_parent"
            android:layout_height="40dp"
            android:hint="Enter network ID"
            android:textSize="14sp"
            android:padding="8dp"
            android:background="@drawable/edit_text_background"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/joinNetworkButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Join Network"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/ztStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Status: Not initialized"
            android:textSize="12sp"
            android:layout_marginTop="8dp" />

        <TextView
            android:id="@+id/ztAddressText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Virtual Address: -"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/ztNetworkIdText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Network ID: -"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/ztPlanetStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Planet config: none"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />

        <TextView
            android:id="@+id/ztMoonStatusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Moon file: none"
            android:textSize="12sp"
            android:layout_marginTop="4dp" />
    </LinearLayout>

    <!-- Settings and Info Buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:layout_weight="1">

        <Button
            android:id="@+id/settingsButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Settings"
            android:layout_marginEnd="8dp" />

        <Button
            android:id="@+id/infoButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Info"
            android:layout_marginStart="8dp" />
    </LinearLayout>

</LinearLayout>
